# 02_synteny_plot.R
#
# Synteny analysis and visualisation between two genomes (Genome_A / Genome_B)
# using whole-genome alignment (PAF, from minimap2) and Gypsy transposable
# element density (GFF for Genome_A, BLAST TSV for Genome_B).
#
# Pipeline:
#   1) Parse Gypsy TE density per genome (GFF for A, BLAST TSV for B) via a
#      shared windowing/summarising function
#   2) Read genome FASTAs and PAF alignment; sanity-check chromosome IDs
#   3) Build a pairwise chromosome synteny score matrix
#   4) Find the optimal one-to-one chromosome assignment that maximises
#      total synteny (Hungarian algorithm via clue::solve_LSAP) -- this
#      avoids naively assuming chr01<->chr01, chr02<->chr02, etc., and
#      instead finds the best-matching chromosome pairs based on actual
#      alignment coverage.
#   5) Compute strict reciprocal synteny using only the assigned best pairs
#   6) Generate per-chromosome-pair synteny + Gypsy-density plots (gggenomes)
#
# Requirements (R packages):
#   gggenomes, ggplot2, dplyr, data.table, clue, scales,
#   GenomicRanges, IRanges (Bioconductor -- see install note below)
#
#   if (!requireNamespace("BiocManager", quietly = TRUE))
#     install.packages("BiocManager")
#   BiocManager::install(c("GenomicRanges", "IRanges"))
#
# Inputs (set below under USER INPUTS):
#   - GD_GFF     : GFF3 annotation for Genome_A, used to extract Gypsy elements
#   - PEAR_BLAST : BLAST outfmt-6 TSV of Gypsy elements vs Genome_B
#                  (output of 01b_blast_gypsy.py)
#   - GD_FASTA   : Genome_A FASTA
#   - PEAR_FASTA : Genome_B FASTA
#   - PAF_FILE   : whole-genome alignment PAF, Genome_A vs Genome_B
#                  (output of 01a_synteny_alignment.slurm)
#
# Outputs (written to OUTDIR):
#   - all_pairwise_chromosome_synteny.csv
#   - assigned_best_pairs.csv
#   - overall_reciprocal_synteny_strict.csv
#   - synteny_<chrA>_vs_<chrB>.png (one plot per assigned chromosome pair)

# Set working directory to the folder containing your input files
# setwd("path/to/your/data")

library(gggenomes)
library(ggplot2)
library(dplyr)
library(data.table)
library(clue)
library(GenomicRanges)
library(IRanges)

