## USER INPUTS
## ══════════════════════════════════════════════════════════════════════════════

GD_GFF       <- "GD.gff3"
PEAR_BLAST   <- "gypsy_vs_genomeDA.tsv"   # <-- change
GD_FASTA     <- "GDT2T_hap1_v1.0.fa"
PEAR_FASTA   <- "Pyrus_hap1.fasta"   # <-- change
PAF_FILE     <- "DA.paf"         # <-- change

OUTDIR       <- "Fusion_DA_B"
N_CHRS       <- 17
WIN_SIZE     <- 1e6
MIN_ALN      <- 5000
MIN_MAPQ     <- 20
MIN_PIDENT   <- 70
MIN_BLASTALN <- 100

dir.create(OUTDIR, showWarnings = FALSE)

